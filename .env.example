CIVICS_DB=/opt/civics/data/civics.db
# Required for initial system-administrator API access. Generate a high-entropy
# secret; never place it in a URL, shell history, repository, or browser storage.
# CIVICS_BOOTSTRAP_ADMIN_TOKEN=replace-with-at-least-32-random-bytes
# Get a key from https://api.congress.gov/sign-up/ and uncomment:
# CONGRESS_API_KEY=replace-me
# Get a key from https://legiscan.com/legiscan and uncomment for state ingestion:
# LEGISCAN_API_KEY=replace-me
# Optional live structured audit provider. This overhaul permits only GPT-5.6 Sol.
# OPENAI_API_KEY=replace-me
# CIVICS_AUDIT_MODEL=gpt-5.6-sol
# Optional email delivery (credentials are never logged):
# CIVICS_SMTP_HOST=smtp.example.org
# CIVICS_SMTP_PORT=587
# CIVICS_SMTP_STARTTLS=true
# CIVICS_SMTP_USERNAME=replace-me
# CIVICS_SMTP_PASSWORD=replace-me
# CIVICS_EMAIL_FROM=civics@example.org
# Optional Telegram delivery:
# CIVICS_TELEGRAM_BOT_TOKEN=replace-me
# Backup retention and destination:
CIVICS_BACKUP_DIR=/opt/civics/backups
CIVICS_BACKUP_RETENTION=14
